{
  "editor.codeActionsOnSave": {
    "source.organizeImports": "explicit",
    "source.fixAll": "explicit"
  },
  "files.eol": "\n",
  "files.insertFinalNewline": true,
  "editor.formatOnSave": true,
  "editor.autoIndent": "advanced",
  "editor.guides.indentation": true,
  "editor.tabSize": 2,
  "[python]": {
    "editor.defaultFormatter": "ms-python.black-formatter",
    "editor.tabSize": 4
  },
  "python.analysis.autoFormatStrings": true,
  "python.analysis.completeFunctionParens": true,
  "python.analysis.autoImportCompletions": true,
  "python.languageServer": "Pylance",
  "python.testing.unittestEnabled": false,
  "python.testing.pytestEnabled": true,
  "chat.tools.terminal.autoApprove": {
    // Explicitly allow your core workflow commands
    "git log": true,
    "git status": true,
    "/^git (log|status).*/": true,
    "/^uv run poe (lint|test|typecheck).*/": true,
    // Explicitly block dangerous commands (Safety first)
    "rm": false,
    "rmdir": false,
    "del": false,
    "curl": false,
    "wget": false
  },
  "chat.tools.edits.autoApprove": {
    // Note: This setting now takes an object mapping file patterns to booleans
    "**/*.{ts,tsx,jsx,js,mjs,cjs,toml,yaml,yml,py,go,rs,cpp,h,css,html,md}": true,
    // PROTECT YOUR SENSITIVE FILES
    "**/.env*": false,
    "**/config/secrets/**": false,
    "**/.aiexclude": false,
    "**/*.{pem,key,pub}": false,
    "**/.agents/tasks/**": true
  },
  "files.exclude": {
    "**/node_modules": true,
    ".venv": true,
    "venv": true,
    "__pycache__": true,
    ".env": true,
    ".env.*": true,
    "dist": true,
    "build": true,
    "**/.agent": false
  }
}
